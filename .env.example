# ═══════════════════════════════════════════════════════════════════════════
# APATRIS COMPLIANCE HUB — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════════════

# ── CRITICAL (app will not start without these) ──────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/apatris
JWT_SECRET=generate-a-random-64-char-hex-string-here
PORT=8080

# ── ADMIN ACCESS (dashboard login will fail without these) ───────────────
APATRIS_PASS_MANISH=your-admin-password
APATRIS_PASS_AKSHAY=your-admin-password

# ── EMAIL / SMTP (alerts and weekly reports won't send without these) ────
SMTP_USER=your-brevo-smtp-user@example.com
SMTP_PASS=your-brevo-smtp-password
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587

# ── AI DOCUMENT SCANNING (passport/certificate OCR won't work without) ──
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-openai-key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── FILE STORAGE (defaults to local filesystem if not set) ───────────────
# FILE_STORAGE=s3
# S3_BUCKET=apatris-documents
# S3_REGION=auto
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# ── WORKFORCE APP (set by Replit artifact config automatically) ──────────
# BASE_PATH=/workforce/
