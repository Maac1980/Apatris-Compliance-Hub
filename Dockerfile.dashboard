FROM nginx:alpine
COPY artifacts/apatris-dashboard/dist/public /usr/share/nginx/html
RUN echo 'server { listen ${PORT:-80}; root /usr/share/nginx/html; index index.html; location / { try_files $uri $uri/ /index.html; } }' > /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["sh", "-c", "sed -i 's/\\${PORT:-80}/'"'"'${PORT:-80}'"'"'/g' /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]
